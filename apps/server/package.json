{
  "name": "server",
  "main": "src/index.ts",
  "type": "module",
  "exports": {
    "./route": {
      "types": "./out/routers/type.d.ts",
      "default": "./src/routers/type.ts"
    },
    "./auth": {
      "types": "./out/core/auth/type.d.ts",
      "default": "./src/core/auth/type.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "dev:debug": "bun run --hot --inspect src/index.ts",
    "auth:generate": "pnpm dlx @better-auth/cli@latest generate --config ./src/core/auth/lib.ts --output ./src/core/auth/schema.ts --yes",
    "start": "bun run dist/index.js",
    "script": "bun run src/script.ts",
    "lint": "biome lint --write",
    "format": "biome format --write",
    "check": "biome check --write",
    "db:seed": "bun ./src/core/db/seed/index.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:start": "docker compose up -d",
    "db:watch": "docker compose up",
    "db:stop": "docker compose stop",
    "db:down": "docker compose down"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1008.0",
    "@aws-sdk/lib-storage": "^3.1009.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@orpc/openapi": "^1.13.7",
    "@orpc/server": "^1.13.7",
    "@orpc/zod": "^1.13.7",
    "@workspace/contracts": "workspace:*",
    "@workspace/core": "workspace:*",
    "axios": "^1.11.0",
    "better-auth": "^1.5.5",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.8.2",
    "link-preview-js": "^3.1.0",
    "nanoid": "^5.1.6",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "progress": "^2.0.3",
    "sharp": "^0.34.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.2.21",

    "@types/pg": "^8.18.0",
    "@types/progress": "^2.0.7",
    "drizzle-kit": "^0.31.10",
    "tsdown": "^0.14.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
