{
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/.classpath": true,
    "**/.factorypath": true,
    "**/.project": true,
    "**/.settings": true,
    "**/node_modules": true
  },
  "cSpell.words": [
    "ilike",
    "orpc"
  ],
  "editor.defaultFormatter": "biomejs.biome",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "explicit"
  },
  "[typescriptreact]": {
      "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
      "editor.defaultFormatter": "biomejs.biome"
  }
}
